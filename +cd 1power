#include <SPI.h>
#include <MFRC522.h>
#include <Keypad.h>
#include <SD.h>

// ---------------- SD ----------------
#define SD_CS_PIN 31  

// ---------------- СЛОВАРЬ ----------------
struct Entry {
  String key1;
  String key2;
  int value;
};

class SimpleDict {
  static const int MAX_SIZE = 10;
  Entry data[MAX_SIZE];
  int size = 0;

public:
  void put(String key1, int value, String key2 = "") {
    for (int i = 0; i < size; i++) {
      if (data[i].key1 == key1 || data[i].key2 == key1) {
        data[i].value = value;
        return;
      }
    }
    if (size < MAX_SIZE) {
      data[size].key1 = key1;
      data[size].key2 = key2;
      data[size].value = value;
      size++;
    }
  }

  bool has(String key) {
    for (int i = 0; i < size; i++) {
      if (data[i].key1 == key || data[i].key2 == key) return true;
    }
    return false;
  }
};

SimpleDict owes;

// ---------------- ПАВЕРЫ ----------------
#define NUM_OF_POWS 3
bool full[NUM_OF_POWS];
bool real_full[NUM_OF_POWS];
String powsUIDs[NUM_OF_POWS];

// ---------------- RFID ----------------
#define SS_PIN1 8
#define SS_PIN2 10
#define RST_PIN1 9
#define RST_PIN2 7

MFRC522 rfid1(SS_PIN1, RST_PIN1);
MFRC522 rfid2(SS_PIN2, RST_PIN2);

// ---------------- КЛАВА ----------------
const byte ROWS = 4;
const byte COLS = 4;

char keys[ROWS][COLS] = {
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};

// 🔴 ТВОЯ РАСПИНОВКА
byte rowPins[ROWS] = {2, 3, 4, 5};
byte colPins[COLS] = {6, A2, A1, A0};

Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

String keyboard_input = "";

// ---------------- ЗУММЕР ----------------
#define ZOOMER_PIN A3

bool alarm = false;

// ---------------- ФУНКЦИИ ----------------

void selectReader(uint8_t n) {
  digitalWrite(SS_PIN1, n == 1 ? LOW : HIGH);
  digitalWrite(SS_PIN2, n == 2 ? LOW : HIGH);
  delay(5);
}

bool tryReadUID(MFRC522 &reader, String &outUID) {
  if (reader.PICC_IsNewCardPresent() && reader.PICC_ReadCardSerial()) {
    outUID = "";
    for (byte i = 0; i < reader.uid.size; i++) {
      if (reader.uid.uidByte[i] < 0x10) outUID += "0";
      outUID += String(reader.uid.uidByte[i], HEX);
    }
    outUID.toUpperCase();
    return true;
  }
  return false;
}

void update_real_full() {
  String uid;
  selectReader(1);

  if (tryReadUID(rfid1, uid)) {
    for (int i = 0; i < NUM_OF_POWS; i++) {
      real_full[i] = (uid == powsUIDs[i]);
    }
  }

  selectReader(0);
}

void security_check() {
  bool flag = false;
  for (int i = 0; i < NUM_OF_POWS; i++) {
    if (full[i] != real_full[i]) flag = true;
  }
  alarm = flag;
  digitalWrite(ZOOMER_PIN, flag ? HIGH : LOW);
}

// ---------------- SD ----------------
bool checkPassword(String pass) {
  File f = SD.open("passwords.txt");
  if (!f) {
    Serial.println("Ошибка SD!");
    return false;
  }

  while (f.available()) {
    String line = f.readStringUntil('\n');
    line.trim();
    if (line == pass) {
      f.close();
      return true;
    }
  }

  f.close();
  return false;
}

// ---------------- SETUP ----------------
void setup() {
  Serial.begin(115200);

  pinMode(SS_PIN1, OUTPUT);
  pinMode(SS_PIN2, OUTPUT);
  pinMode(ZOOMER_PIN, OUTPUT);

  SPI.begin();

  selectReader(1); rfid1.PCD_Init();
  selectReader(2); rfid2.PCD_Init();
  selectReader(0);

  if (!SD.begin(SD_CS_PIN)) {
    Serial.println("❌ SD не работает");
  } else {
    Serial.println("✅ SD OK");
  }

  for (int i = 0; i < NUM_OF_POWS; i++) {
    full[i] = true;
    real_full[i] = true;
  }

  powsUIDs[0] = "129AA104";
  powsUIDs[1] = "A25F6206";
  powsUIDs[2] = "09B0C801";

  Serial.println("🚀 Система запущена");
}

// ---------------- LOOP ----------------
void loop() {

  // 🔴 ТЕСТ КЛАВИАТУРЫ
  char key = keypad.getKey();
  if (key) {
    Serial.print("KEY: ");
    Serial.println(key);

    if (key == '#') {
      keyboard_input = "";
    } else {
      keyboard_input += key;
    }

    if (keyboard_input.length() == 6) {
      Serial.print("Пароль: ");
      Serial.println(keyboard_input);

      if (checkPassword(keyboard_input)) {
        Serial.println("✅ ДОСТУП");
      } else {
        Serial.println("❌ НЕВЕРНЫЙ ПАРОЛЬ");
      }

      keyboard_input = "";
    }
  }

  // RFID → только контроль наличия
  update_real_full();

  // Аларм если павер пропал
  security_check();

  delay(100);
}
